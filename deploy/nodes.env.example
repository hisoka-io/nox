# Node definitions: name:ip:role
# Copy this file to nodes.env and fill in your node IPs.
# Format: "name:ip:role" where role is entry|mix|exit
NODES=(
    "nox-1:YOUR_IP_1:entry"
    "nox-2:YOUR_IP_2:entry"
    "nox-3:YOUR_IP_3:mix"
    "nox-4:YOUR_IP_4:mix"
    "nox-5:YOUR_IP_5:mix"
    "nox-6:YOUR_IP_6:exit"
    "nox-7:YOUR_IP_7:exit"
    "nox-8:YOUR_IP_8:mix"
    "nox-9:YOUR_IP_9:mix"
    "nox-10:YOUR_IP_10:exit"
)
